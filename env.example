# Copy this file to `.env` in the same directory (`subnet32_dataset/`) and fill in values.
# The dataset builder loads `.env` automatically when `python-dotenv` is installed
# (`pip install -r requirements.txt`). Existing real environment variables are not overwritten.
#
# Never commit `.env` or real keys.

# --- OpenAI (platform API) — use when `openai.use_azure` is false in configs/models.yaml ---
# OPENAI_API_KEY=
# Optional:
# OPENAI_ORGANIZATION=

# --- Azure OpenAI — use when `openai.use_azure: true` and `api_key_env: AZURE_OPENAI_API_KEY` ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Hugging Face (optional; helps with rate limits / private caches) ---
# HF_TOKEN=

# --- Hub download tuning (optional) ---
# HF_HUB_DOWNLOAD_TIMEOUT=600
# HF_HUB_ENABLE_HF_TRANSFER=1

# --- Ollama (optional; usually set in the shell that runs `ollama serve`) ---
# OLLAMA_HOST=127.0.0.1:11434
# OLLAMA_NUM_PARALLEL=2

# --- GPU binding for Ollama servers (optional) ---
# CUDA_VISIBLE_DEVICES=0
